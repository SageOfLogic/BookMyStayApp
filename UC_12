import java.io.*;
import java.util.*;

public class BookMyStayApp {

    public static void main(String[] args) {

        PersistenceService persistence = new PersistenceService("data.ser");

        SystemState state = persistence.load();

        if (state == null) {
            state = new SystemState(new Inventory(), new BookingHistory());
            state.getInventory().setAvailability("DELUXE", 2);
            state.getInventory().setAvailability("STANDARD", 1);
        }

        BookingService bookingService = new BookingService(state.getInventory(), state.getHistory());

        bookingService.confirm(new Reservation("Niranjan", "DELUXE"));
        bookingService.confirm(new Reservation("Arun", "STANDARD"));

        persistence.save(state);
    }
}

class SystemState implements Serializable {
    private Inventory inventory;
    private BookingHistory history;

    public SystemState(Inventory inventory, BookingHistory history) {
        this.inventory = inventory;
        this.history = history;
    }

    public Inventory getInventory() {
        return inventory;
    }

    public BookingHistory getHistory() {
        return history;
    }
}

class Reservation implements Serializable {
    private String guestName;
    private String roomType;
    private String roomId;

    public Reservation(String guestName, String roomType) {
        this.guestName = guestName;
        this.roomType = roomType;
    }

    public String getGuestName() {
        return guestName;
    }

    public String getRoomType() {
        return roomType;
    }

    public String getRoomId() {
        return roomId;
    }

    public void setRoomId(String roomId) {
        this.roomId = roomId;
    }

    @Override
    public String toString() {
        return guestName + " | " + roomType + " | " + roomId;
    }
}

class Inventory implements Serializable {
    private Map<String, Integer> data = new HashMap<>();

    public void setAvailability(String type, int count) {
        data.put(type, count);
    }

    public int getAvailability(String type) {
        return data.getOrDefault(type, 0);
    }

    public void decrement(String type) {
        data.put(type, getAvailability(type) - 1);
    }

    public Map<String, Integer> getAll() {
        return data;
    }
}

class BookingHistory implements Serializable {
    private List<Reservation> list = new ArrayList<>();

    public void add(Reservation r) {
        list.add(r);
    }

    public List<Reservation> getAll() {
        return list;
    }
}

class BookingService {

    private Inventory inventory;
    private BookingHistory history;
    private Set<String> usedIds = new HashSet<>();

    public BookingService(Inventory inventory, BookingHistory history) {
        this.inventory = inventory;
        this.history = history;
    }

    public void confirm(Reservation r) {
        String type = r.getRoomType();

        if (inventory.getAvailability(type) <= 0) {
            System.out.println("Unavailable: " + r.getGuestName());
            return;
        }

        String id = generate(type);

        usedIds.add(id);
        inventory.decrement(type);

        r.setRoomId(id);
        history.add(r);

        System.out.println("Confirmed: " + r.getGuestName() + " -> " + id);
    }

    private String generate(String type) {
        String id;
        do {
            id = type + "-" + UUID.randomUUID().toString().substring(0, 5);
        } while (usedIds.contains(id));
        return id;
    }
}

class PersistenceService {

    private String fileName;

    public PersistenceService(String fileName) {
        this.fileName = fileName;
    }

    public void save(SystemState state) {
        try (ObjectOutputStream out = new ObjectOutputStream(new FileOutputStream(fileName))) {
            out.writeObject(state);
            System.out.println("State saved");
        } catch (Exception e) {
            System.out.println("Save failed");
        }
    }

    public SystemState load() {
        try (ObjectInputStream in = new ObjectInputStream(new FileInputStream(fileName))) {
            System.out.println("State loaded");
            return (SystemState) in.readObject();
        } catch (Exception e) {
            System.out.println("No previous state found");
            return null;
        }
    }
}
