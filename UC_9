import java.util.*;

public class BookMyStayApp {

    public static void main(String[] args) {

        Inventory inventory = new Inventory();
        inventory.setAvailability("DELUXE", 1);
        inventory.setAvailability("STANDARD", 1);

        Set<String> validRoomTypes = new HashSet<>(Arrays.asList("DELUXE", "STANDARD"));

        BookingRequestQueue queue = new BookingRequestQueue();
        queue.addRequest(new Reservation("Niranjan", "DELUXE"));
        queue.addRequest(new Reservation("Arun", "SUITE"));
        queue.addRequest(new Reservation("Priya", "STANDARD"));
        queue.addRequest(new Reservation("", "DELUXE"));

        BookingService bookingService = new BookingService(inventory, validRoomTypes);

        while (!queue.isEmpty()) {
            try {
                bookingService.process(queue.processNextRequest());
            } catch (BookingException e) {
                System.out.println("Error: " + e.getMessage());
            }
        }
    }
}

class Reservation {
    private String guestName;
    private String roomType;

    public Reservation(String guestName, String roomType) {
        this.guestName = guestName;
        this.roomType = roomType;
    }

    public String getGuestName() {
        return guestName;
    }

    public String getRoomType() {
        return roomType;
    }
}

class BookingRequestQueue {
    private Queue<Reservation> queue = new LinkedList<>();

    public void addRequest(Reservation r) {
        if (r != null) queue.offer(r);
    }

    public Reservation processNextRequest() {
        return queue.poll();
    }

    public boolean isEmpty() {
        return queue.isEmpty();
    }
}

class Inventory {
    private Map<String, Integer> data = new HashMap<>();

    public void setAvailability(String type, int count) {
        data.put(type, count);
    }

    public int getAvailability(String type) {
        return data.getOrDefault(type, 0);
    }

    public void decrement(String type) {
        int current = getAvailability(type);
        if (current <= 0) {
            throw new BookingException("No availability for room type: " + type);
        }
        data.put(type, current - 1);
    }
}

class BookingService {

    private Inventory inventory;
    private Set<String> validRoomTypes;
    private Set<String> usedIds = new HashSet<>();

    public BookingService(Inventory inventory, Set<String> validRoomTypes) {
        this.inventory = inventory;
        this.validRoomTypes = validRoomTypes;
    }

    public void process(Reservation r) {
        validate(r);

        String type = r.getRoomType();

        if (inventory.getAvailability(type) <= 0) {
            throw new BookingException("Room not available: " + type);
        }

        String id = generateId(type);

        usedIds.add(id);
        inventory.decrement(type);

        System.out.println("Confirmed: " + r.getGuestName() + " -> " + id);
    }

    private void validate(Reservation r) {
        if (r == null) {
            throw new BookingException("Reservation cannot be null");
        }

        if (r.getGuestName() == null || r.getGuestName().trim().isEmpty()) {
            throw new BookingException("Invalid guest name");
        }

        if (r.getRoomType() == null || !validRoomTypes.contains(r.getRoomType())) {
            throw new BookingException("Invalid room type: " + r.getRoomType());
        }
    }

    private String generateId(String type) {
        String id;
        do {
            id = type + "-" + UUID.randomUUID().toString().substring(0, 5);
        } while (usedIds.contains(id));
        return id;
    }
}

class BookingException extends RuntimeException {
    public BookingException(String message) {
        super(message);
    }
}
