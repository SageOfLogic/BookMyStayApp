import java.util.*;

public class BookMyStayApp {

    public static void main(String[] args) {

        Inventory inventory = new Inventory();
        inventory.setAvailability("DELUXE", 2);
        inventory.setAvailability("STANDARD", 1);

        BookingRequestQueue queue = new BookingRequestQueue();
        queue.addRequest(new Reservation("Niranjan", "DELUXE"));
        queue.addRequest(new Reservation("Arun", "DELUXE"));
        queue.addRequest(new Reservation("Priya", "STANDARD"));

        BookingHistory history = new BookingHistory();
        BookingService bookingService = new BookingService(inventory, history);

        while (!queue.isEmpty()) {
            bookingService.process(queue.processNextRequest());
        }

        BookingReportService reportService = new BookingReportService(history);

        reportService.showAllBookings();
        reportService.showSummary();
    }
}

class Reservation {
    private String guestName;
    private String roomType;
    private String roomId;

    public Reservation(String guestName, String roomType) {
        this.guestName = guestName;
        this.roomType = roomType;
    }

    public String getGuestName() {
        return guestName;
    }

    public String getRoomType() {
        return roomType;
    }

    public String getRoomId() {
        return roomId;
    }

    public void setRoomId(String roomId) {
        this.roomId = roomId;
    }

    @Override
    public String toString() {
        return guestName + " | " + roomType + " | " + roomId;
    }
}

class BookingRequestQueue {
    private Queue<Reservation> queue = new LinkedList<>();

    public void addRequest(Reservation r) {
        if (r != null) queue.offer(r);
    }

    public Reservation processNextRequest() {
        return queue.poll();
    }

    public boolean isEmpty() {
        return queue.isEmpty();
    }
}

class Inventory {
    private Map<String, Integer> data = new HashMap<>();

    public void setAvailability(String type, int count) {
        data.put(type, count);
    }

    public int getAvailability(String type) {
        return data.getOrDefault(type, 0);
    }

    public void update(String type) {
        data.put(type, getAvailability(type) - 1);
    }
}

class BookingHistory {
    private List<Reservation> history = new ArrayList<>();

    public void add(Reservation r) {
        history.add(r);
    }

    public List<Reservation> getAll() {
        return Collections.unmodifiableList(history);
    }
}

class BookingService {

    private Inventory inventory;
    private BookingHistory history;
    private Set<String> usedIds = new HashSet<>();

    public BookingService(Inventory inventory, BookingHistory history) {
        this.inventory = inventory;
        this.history = history;
    }

    public void process(Reservation r) {
        if (r == null) return;

        String type = r.getRoomType();

        if (inventory.getAvailability(type) <= 0) {
            System.out.println("Rejected: " + r.getGuestName());
            return;
        }

        String id = generateId(type);

        usedIds.add(id);
        inventory.update(type);

        r.setRoomId(id);
        history.add(r);

        System.out.println("Confirmed: " + r.getGuestName() + " -> " + id);
    }

    private String generateId(String type) {
        String id;
        do {
            id = type + "-" + UUID.randomUUID().toString().substring(0, 6);
        } while (usedIds.contains(id));
        return id;
    }
}

class BookingReportService {

    private BookingHistory history;

    public BookingReportService(BookingHistory history) {
        this.history = history;
    }

    public void showAllBookings() {
        System.out.println("\nBooking History:");
        for (Reservation r : history.getAll()) {
            System.out.println(r);
        }
    }

    public void showSummary() {
        Map<String, Integer> summary = new HashMap<>();

        for (Reservation r : history.getAll()) {
            summary.put(r.getRoomType(),
                    summary.getOrDefault(r.getRoomType(), 0) + 1);
        }

        System.out.println("\nSummary Report:");
        for (Map.Entry<String, Integer> e : summary.entrySet()) {
            System.out.println(e.getKey() + " -> " + e.getValue());
        }
    }
}
