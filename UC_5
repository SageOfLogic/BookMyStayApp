import java.util.*;

public class BookMyStayApp {

    public static void main(String[] args) {

        BookingRequestQueue requestQueue = new BookingRequestQueue();

        requestQueue.addRequest(new Reservation("Niranjan", "DELUXE"));
        requestQueue.addRequest(new Reservation("Arun", "SUITE"));
        requestQueue.addRequest(new Reservation("Priya", "STANDARD"));

        System.out.println("Booking Requests in Queue (FIFO Order):");
        requestQueue.displayQueue();
    }
}

class Reservation {
    private String guestName;
    private String roomType;

    public Reservation(String guestName, String roomType) {
        this.guestName = guestName;
        this.roomType = roomType;
    }

    public String getGuestName() {
        return guestName;
    }

    public String getRoomType() {
        return roomType;
    }

    @Override
    public String toString() {
        return "Guest: " + guestName + ", Requested Room: " + roomType;
    }
}

class BookingRequestQueue {

    private Queue<Reservation> queue;

    public BookingRequestQueue() {
        queue = new LinkedList<>(); // FIFO Queue
    }

    public void addRequest(Reservation reservation) {
        if (reservation == null) {
            System.out.println("Invalid booking request.");
            return; // Defensive programming
        }

        queue.offer(reservation);
        System.out.println("Request added: " + reservation);
    }

    public Reservation peekNextRequest() {
        return queue.peek();
    }

    public Reservation processNextRequest() {
        return queue.poll(); // FIFO removal
    }

    public void displayQueue() {
        if (queue.isEmpty()) {
            System.out.println("No booking requests.");
            return;
        }

        for (Reservation r : queue) {
            System.out.println(r);
        }
    }
}
