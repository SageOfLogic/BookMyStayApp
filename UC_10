import java.util.*;

public class BookMyStayApp {

    public static void main(String[] args) {

        Inventory inventory = new Inventory();
        inventory.setAvailability("DELUXE", 1);
        inventory.setAvailability("STANDARD", 1);

        BookingHistory history = new BookingHistory();

        BookingService bookingService = new BookingService(inventory, history);

        Reservation r1 = new Reservation("Niranjan", "DELUXE");
        Reservation r2 = new Reservation("Arun", "STANDARD");

        bookingService.confirm(r1);
        bookingService.confirm(r2);

        CancellationService cancellationService = new CancellationService(inventory, history);

        cancellationService.cancel(r1.getRoomId());
        cancellationService.cancel("INVALID-ID");

        cancellationService.showRollbackStack();
    }
}

class Reservation {
    private String guestName;
    private String roomType;
    private String roomId;
    private boolean active = true;

    public Reservation(String guestName, String roomType) {
        this.guestName = guestName;
        this.roomType = roomType;
    }

    public String getGuestName() {
        return guestName;
    }

    public String getRoomType() {
        return roomType;
    }

    public String getRoomId() {
        return roomId;
    }

    public void setRoomId(String roomId) {
        this.roomId = roomId;
    }

    public boolean isActive() {
        return active;
    }

    public void cancel() {
        this.active = false;
    }

    @Override
    public String toString() {
        return guestName + " | " + roomType + " | " + roomId + " | " + active;
    }
}

class Inventory {
    private Map<String, Integer> data = new HashMap<>();

    public void setAvailability(String type, int count) {
        data.put(type, count);
    }

    public int getAvailability(String type) {
        return data.getOrDefault(type, 0);
    }

    public void decrement(String type) {
        data.put(type, getAvailability(type) - 1);
    }

    public void increment(String type) {
        data.put(type, getAvailability(type) + 1);
    }
}

class BookingHistory {
    private List<Reservation> list = new ArrayList<>();

    public void add(Reservation r) {
        list.add(r);
    }

    public List<Reservation> getAll() {
        return list;
    }

    public Reservation findByRoomId(String id) {
        for (Reservation r : list) {
            if (id.equals(r.getRoomId())) return r;
        }
        return null;
    }
}

class BookingService {

    private Inventory inventory;
    private BookingHistory history;
    private Set<String> usedIds = new HashSet<>();

    public BookingService(Inventory inventory, BookingHistory history) {
        this.inventory = inventory;
        this.history = history;
    }

    public void confirm(Reservation r) {
        String type = r.getRoomType();

        if (inventory.getAvailability(type) <= 0) {
            System.out.println("Unavailable: " + r.getGuestName());
            return;
        }

        String id = generate(type);

        usedIds.add(id);
        inventory.decrement(type);

        r.setRoomId(id);
        history.add(r);

        System.out.println("Confirmed: " + r.getGuestName() + " -> " + id);
    }

    private String generate(String type) {
        String id;
        do {
            id = type + "-" + UUID.randomUUID().toString().substring(0, 5);
        } while (usedIds.contains(id));
        return id;
    }
}

class CancellationService {

    private Inventory inventory;
    private BookingHistory history;
    private Stack<String> rollbackStack = new Stack<>();

    public CancellationService(Inventory inventory, BookingHistory history) {
        this.inventory = inventory;
        this.history = history;
    }

    public void cancel(String roomId) {

        Reservation r = history.findByRoomId(roomId);

        if (r == null) {
            System.out.println("Invalid cancellation: " + roomId);
            return;
        }

        if (!r.isActive()) {
            System.out.println("Already cancelled: " + roomId);
            return;
        }

        rollbackStack.push(roomId);

        inventory.increment(r.getRoomType());

        r.cancel();

        System.out.println("Cancelled: " + roomId);
    }

    public void showRollbackStack() {
        System.out.println("\nRollback Stack:");
        for (String id : rollbackStack) {
            System.out.println(id);
        }
    }
}
